#!/bin/sh
LUA_BIN="/opt/homebrew/bin/lua5.5"

if [ ! -x "$LUA_BIN" ]; then
  echo "sketchybarrc: lua not found at $LUA_BIN. Check nix-darwin packages." >&2
  exit 1
fi

# why: Luaのrequireはカレントディレクトリ基準で解決するため、cdが必要
cd "$HOME/.config/sketchybar"
# why: sbar.exec()はshサブプロセスで実行されるため、CONFIG_DIRを明示的に渡す
export CONFIG_DIR="$HOME/.config/sketchybar"
export SKETCHYBAR_GH_USER="koshiishi_sansan"
exec "$LUA_BIN" "$HOME/.config/sketchybar/init.lua"
