#!/bin/sh
# why: LaunchAgent環境ではPATHが最小限なので、lua実体を候補順で解決する
LUA_BIN=""

# Prefer an installed mise Lua without requiring global activation.
for candidate in "$HOME"/.local/share/mise/installs/lua/*/bin/lua; do
  if [ -x "$candidate" ]; then
    LUA_BIN="$candidate"
    break
  fi
done

# Fallbacks for common package managers/paths.
if [ -z "$LUA_BIN" ]; then
  for candidate in \
    "$HOME/.local/share/mise/shims/lua" \
    "/opt/homebrew/bin/lua" \
    "/usr/local/bin/lua"
  do
    if [ -x "$candidate" ]; then
      LUA_BIN="$candidate"
      break
    fi
  done
fi

if [ -z "$LUA_BIN" ]; then
  echo "sketchybarrc: lua runtime not found. Install one via 'brew install lua'." >&2
  exit 1
fi

exec "$LUA_BIN" "$HOME/.config/sketchybar/init.lua"
