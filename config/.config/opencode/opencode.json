{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/deepseek-v4-pro",
  "small_model": "opencode-go/deepseek-v4-flash",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "opencode-go/deepseek-v4-pro",
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "plan": {
      "mode": "primary",
      "model": "opencode-go/deepseek-v4-pro",
      "permission": {
        "edit": "ask",
        "bash": "ask"
      }
    },
    "research": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash"
    },
    "playwright-browser-verifier": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash"
    },
    "review-verifier": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash"
    },
    "general": {
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash"
    }
  },
  "permission": {
    "edit": "allow",
    "bash": {
      "*": "ask",
      "git *": "allow",
      "mise *": "allow",
      "mise": "allow",
      "task *": "allow",
      "task": "allow",
      "go *": "allow",
      "go": "allow",
      "npm *": "allow",
      "npm": "allow",
      "yarn *": "allow",
      "yarn": "allow",
      "bun *": "allow",
      "bun": "allow",
      "pnpm *": "allow",
      "pnpm": "allow",
      "ls *": "allow",
      "ls": "allow",
      "cat *": "allow",
      "cat": "allow",
      "find *": "allow",
      "rg *": "allow",
      "rg": "allow",
      "grep *": "allow",
      "grep": "allow",
      "head *": "allow",
      "head": "allow",
      "tail *": "allow",
      "tail": "allow",
      "wc *": "allow",
      "wc": "allow",
      "stat *": "allow",
      "stat": "allow",
      "du *": "allow",
      "du": "allow",
      "diff *": "allow",
      "diff": "allow",
      "file *": "allow",
      "file": "allow",
      "pwd": "allow",
      "whoami": "allow",
      "uname *": "allow",
      "uname": "allow",
      "date": "allow",
      "echo *": "allow",
      "ctx7 *": "allow",
      "ctx7": "allow",
      "cd *": "allow",
      "cd": "allow",
