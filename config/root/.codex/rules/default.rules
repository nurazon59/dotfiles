# Skill installer
prefix_rule(pattern=["python", "/Users/itsuki54/.codex/skills/.system/skill-installer/scripts/install-skill-from-github.py", "--repo", "openai/skills", "--path", "skills/.curated/gh-address-comments", "skills/.curated/gh-fix-ci", "skills/.curated/notion-knowledge-capture", "skills/.curated/notion-meeting-intelligence", "skills/.curated/notion-research-documentation", "skills/.curated/notion-spec-to-implementation"], decision="allow")

